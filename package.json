{
  "name": "silver-crown-pti",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev:mobile": "pnpm --filter @silver-crown/mobile start",
    "dev:web": "pnpm --filter @silver-crown/web dev",
    "build:web": "pnpm --filter @silver-crown/web build",
    "test": "npx jest",
    "test:watch": "npx jest --watch",
    "emulators": "firebase emulators:start --import=./firebase/emulator-data --export-on-exit",
    "emulators:exec": "firebase emulators:exec --only auth,firestore,storage,functions \"npx jest packages/shared/src/__tests__/firestore.rules.test.ts\"",
    "seed": "tsx firebase/seed.ts",
    "seed:production": "tsx firebase/seed-production.ts",
    "lint": "pnpm -r lint"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^4.0.1",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.13.10",
    "firebase-tools": "^13.34.0",
    "firebase-admin": "^13.2.0",
    "dotenv": "^16.4.7",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.6",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
