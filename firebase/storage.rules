rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Auth-only checks — Firestore cross-service lookups are unavailable on this project.
    match /companies/{companyId}/drivers/{driverId}/inspections/{inspectionId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == driverId;
    }
  }
}
